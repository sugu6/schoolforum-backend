# ============================================
# 校园论坛后端 - 生产环境变量配置
# 将此文件复制为 .env 并填写实际值
# ============================================

# ---- 必需配置 ----

# JWT 密钥（必须设置，生产环境禁止使用默认值）
# 建议使用 64 位以上的随机字符串，例如: openssl rand -base64 64
JWT_SECRET_KEY=

# 数据库连接（Docker 容器内使用 host.docker.internal 访问宿主机）
DB_URL=jdbc:mysql://host.docker.internal:3306/schoolforum?characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=

# Redis 连接（Docker 容器内使用 host.docker.internal 访问宿主机）
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- 可选配置 ----

# 服务器地址（默认 0.0.0.0）
SERVER_ADDRESS=0.0.0.0

# Manticore 搜索引擎（docker-compose 内部使用 http://manticore）
MANTICORE_HOST=http://manticore
MANTICORE_PORT=9308

# 邮件服务
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=

# JVM 参数
JAVA_OPTS=-Xms256m -Xmx512m

# 日志路径
LOG_PATH=/var/log/schoolforum

# 文件上传路径
UPLOAD_AVATAR_PATH=/app/uploads/avatars/
UPLOAD_POST_IMAGE_PATH=/app/uploads/post-images/
